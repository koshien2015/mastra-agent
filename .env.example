QDRANT_URL=http://localhost:6333

SCORESHEET_API_URL=http://localhost:3333

# Ollama model (default: llama3.1)
OLLAMA_MODEL=llama3.1

# Article Recommend Workflow — Silent Concierge
# CONCIERGE_USERS: カンマ区切りの GitHub username（gh auth login 済みであること）
# CONCIERGE_ORG: 組織名（省略可。指定するとorg内リポジトリ情報も収集）
CONCIERGE_USERS=sample1,sample2
CONCIERGE_ORG=org1
